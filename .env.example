# ===== 应用 =====
APP_ENV=development

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===== MySQL =====
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=rec_user
MYSQL_PASSWORD=rec_pass
MYSQL_DATABASE=rec_platform

# ===== ClickHouse =====
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=rec_monitor

# ===== LLM =====
LLM_BACKEND=openai_compatible
LLM_BASE_URL=http://localhost:8001/v1
LLM_API_KEY=EMPTY
LLM_MODEL=qwen2.5-7b-instruct

# ===== Server =====
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=1
LOG_LEVEL=INFO
